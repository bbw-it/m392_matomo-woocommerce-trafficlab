# Lokale Konfiguration & Secrets: echte .env nie versionieren …
.env
# … die Vorlage .env.example dagegen MUSS mit ins Repo (explizit nicht ignorieren).
!.env.example

# WordPress-Docroot (Bind-Mount): wird beim Start generiert bzw. aus der Fixture
# wiederhergestellt -> nicht versionieren. Eigene Importe landen hier lokal.
wordpress/www/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# Fixtures fuer die reproduzierbare Demo-Umgebung MUESSEN versioniert werden,
# daher hier explizit NICHT ignorieren (schuetzt auch gegen kuenftige breite
# Dump-Filter wie *.gz/*.sql). Zwei Saetze:
#  (1) Shop      -> wordpress/init/fixture/  (DB-Dump + Uploads-Archiv)
#  (2) Historie  -> matomo/fixture/          (Matomo-Logs + WC-Bestellungen + Anker/Info),
#                   wird von install.sh [5/5] restauriert + auf "heute" geshiftet.
!wordpress/init/fixture/
!wordpress/init/fixture/shop.sql.gz
!wordpress/init/fixture/uploads.tar.gz
!matomo/fixture/
!matomo/fixture/matomo-history.sql.gz
!matomo/fixture/wc-orders.sql.gz
!matomo/fixture/BASE
!matomo/fixture/BAKE-INFO
