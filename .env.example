# ----- Host-Ports -----
WORDPRESS_PORT=8090
MATOMO_PORT=8091
TRAFFIC_PORT=8092

# ----- Image-Versionen (gepinnt, bei Bedarf hier anpassen) -----
MARIADB_VERSION=11.4
WORDPRESS_VERSION=6.7-php8.3-apache
WORDPRESS_CLI_VERSION=2.11
MATOMO_VERSION=5.3.0
WOOCOMMERCE_VERSION=9.5.1

# ----- Datenbank -----
MYSQL_ROOT_PASSWORD=root123
WP_DB_NAME=wordpress
WP_DB_USER=wp
WP_DB_PASSWORD=wp123
MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=matomo123

# ----- WordPress / Shop -----
WP_LOCALE=de_CH
WP_TITLE=M392 Demo-Shop
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=wp123
WP_ADMIN_EMAIL=admin@example.com
SHOP_CURRENCY=EUR
SHOP_COUNTRY=DE

# ----- Matomo Superuser -----
MATOMO_ADMIN_USER=admin
MATOMO_ADMIN_PASSWORD=matomo123
MATOMO_ADMIN_EMAIL=admin@example.com

# ----- Traffic-Generator -----
TRAFFIC_AUTO_SEED=true
TRAFFIC_BACKFILL_DAYS=90                   # Historie beim Start (~3 Monate). Senkt die Startlast deutlich
                                           # ggü. 180 (halbe Besuche + halbe Bestellungen), ohne Realismus-Verlust.
TRAFFIC_LIVE_DRIP=true
TRAFFIC_CONVERSION_RATE=0.014
TRAFFIC_RETURNING_RATE=0.08               # Anteil wiederkehrender Bestandskund:innen (0..1)
TRAFFIC_DRIP_VISITS_PER_HOUR=120

# Echte WooCommerce-Bestellungen (sichtbar unter WooCommerce -> Bestellungen)
M392_ORDER_API_KEY=m392_lab_9f1bbcd0f2ed0e652af4f6d95819953263a07e4c   # gemeinsames Secret WP <-> Traffic Lab
TRAFFIC_CREATE_WC_ORDERS=true             # Drip-/Manuell-Käufe als echte Bestellungen anlegen
TRAFFIC_SEED_ORDERS=120                   # Startseed: Bestellungen über das ganze Fenster (Anzahl-Modus)
TRAFFIC_SEED_ORDERS_DAYS=90               # Startseed-Fenster (Standard = Matomo-Historie)
# Richtwert: Ø Bestell-Umsatz pro Monat (EUR). > 0 => bestimmt die Bestellmenge so,
# dass der Monatsumsatz etwa diesem Betrag entspricht (hat Vorrang vor TRAFFIC_SEED_ORDERS).
# Leer/0 => klassischer Anzahl-Modus. Beispiel: 1500 (~50 Bestellungen/Monat bei Ø ~30 EUR).
TRAFFIC_AVG_MONTHLY_REVENUE=1500

# ----- Startlast / Install-Dauer steuern -------------------------------------
# Formel (gekoppelter Modus): Bestellungen/Tag = (MONATSUMSATZ/30)/28;
#   Backfill-Besuche/Tag = Bestellungen/Tag x (1/CR - 1); x TAGE.
# Die zwei Kostenblöcke: echte WooCommerce-Bestellungen (langsam) + Besuche (viele Requests).
#   - TAGE runter  -> senkt BEIDES linear (bester Hebel, ~kein Realismusverlust). << Standard nutzt 90.
#   - MONATSUMSATZ runter -> senkt BEIDES linear (kleinerer Shop).
#   - CR hoch -> senkt nur die Besuche (1/CR-1), nicht die Bestellungen; kostet etwas Realismus.
#   - AVG_MONTHLY_REVENUE=0 -> Kopplung aus, Besuche/Tag fix 14 (~9x weniger), Bestellungen aus SEED_ORDERS.
#   - TRAFFIC_AUTO_SEED=false -> gar kein Seed (instant, leere Historie; nur Live-Tropf).
# Beispiel-Profile (Besuche / Bestellungen, geschätzt):
#   Standard (jetzt) : DAYS=90,  REVENUE=1500              -> ~11 000 / ~160
#   Schnell          : DAYS=60,  REVENUE=600, CR=0.03      -> ~1 400  / ~43
#   Minimal/entkoppelt: DAYS=90, REVENUE=0,   SEED_ORDERS=60 -> ~1 260 / 60
#   Kein Seed        : TRAFFIC_AUTO_SEED=false              -> 0 / 0
# -----------------------------------------------------------------------------

# A/B-Test der Shop-Seite (Variante A/B; getrackt in Matomo Custom-Dimension "AB-Variante")
M392_AB_TEST_ENABLED=true                 # A/B-Test aktiv
M392_AB_SPLIT_B=50                        # Prozent der Besucher:innen -> Variante B
M392_AB_CONV_FACTOR_B=1.25                # Variante B konvertiert um diesen Faktor besser (Lerneffekt)
