# ----- Host-Ports (FIX: Teil der Kursumgebung; nur bewusst overriden) -----
# Gebunden an 127.0.0.1 (nur localhost erreichbar, kein LAN). Tracker-/Katalog-
# URLs gehen fest auf 8090/8091 → diese Ports nicht ohne Grund ändern.
WORDPRESS_PORT=8090
MATOMO_PORT=8091
TRAFFIC_PORT=8092

# ----- Image-Versionen (gepinnt, bei Bedarf hier anpassen) -----
MARIADB_VERSION=11.4
WORDPRESS_VERSION=6.7-php8.3-apache
WORDPRESS_CLI_VERSION=2.11
MATOMO_VERSION=5.3.0

# ----- Datenbank -----
MYSQL_ROOT_PASSWORD=root123
WP_DB_NAME=wordpress
WP_DB_USER=wp
WP_DB_PASSWORD=wp123
MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=matomo123

# ----- WordPress-Admin (Shop-Inhalt/Sprache/Währung kommen aus der Fixture) -----
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=wp123
WP_ADMIN_EMAIL=admin@example.com

# ----- Matomo Superuser -----
MATOMO_ADMIN_USER=admin
MATOMO_ADMIN_PASSWORD=matomo123
MATOMO_ADMIN_EMAIL=admin@example.com

# ----- Traffic Lab: Live-Tropf -----
# Die HISTORIE (Monate an Besuchen/Bestellungen) ist als Fixture eingebacken
# (matomo/fixture/*) und wird beim Install nur restauriert + auf „heute" verschoben.
# Diese Werte steuern NUR den laufenden Live-Tropf. Historienlänge/Umsatz/CR der
# Fixture ändern ⇒ tools/bake.conf anpassen und neu backen: ./tools/bake-fixture.sh
TRAFFIC_LIVE_DRIP=true                     # laufende Besuche/Käufe beim Start aktiv (in der UI abschaltbar)
TRAFFIC_DRIP_VISITS_PER_HOUR=120           # Startwert: Besucher/Stunde des Live-Tropfs
TRAFFIC_CONVERSION_RATE=0.014              # Anteil Besuche mit Kauf (0..1)
TRAFFIC_RETURNING_RATE=0.08                # Anteil wiederkehrender Bestandskund:innen (0..1)

# Echte WooCommerce-Bestellungen (sichtbar unter WooCommerce -> Bestellungen)
M392_ORDER_API_KEY=m392_lab_9f1bbcd0f2ed0e652af4f6d95819953263a07e4c   # gemeinsames Secret WP <-> Traffic Lab
TRAFFIC_CREATE_WC_ORDERS=true             # Live-Käufe als echte Bestellungen anlegen

# A/B-Test der Shop-Seite (Variante A/B; getrackt in Matomo Custom-Dimension "AB-Variante")
M392_AB_TEST_ENABLED=true                 # A/B-Test aktiv
M392_AB_SPLIT_B=50                        # Prozent der Besucher:innen -> Variante B
M392_AB_CONV_FACTOR_B=1.25                # Variante B konvertiert um diesen Faktor besser (Lerneffekt)
