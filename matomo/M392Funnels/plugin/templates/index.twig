<div style="padding:24px 28px;max-width:760px;font-family:inherit;">
  <h2 style="margin:0 0 4px;">Conversion-Trichter (M392)</h2>
  <p style="color:#666;margin:0 0 22px;">Klassischer E-Commerce-Funnel · {{ prettyDate }}</p>

  {% for s in steps %}
    <div style="margin:0 0 14px;">
      <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:4px;">
        <strong>{{ loop.index }}. {{ s.label }}</strong>
        <span>{{ s.count }} &nbsp;<span style="color:#888;">({{ s.pct_total }}% vom Start)</span></span>
      </div>
      <div style="background:#eef0f2;border-radius:8px;overflow:hidden;height:34px;position:relative;">
        <div style="height:100%;width:{{ s.pct_total }}%;min-width:2%;
                    background:linear-gradient(90deg,#2e7d9a,#3aa0c2);
                    display:flex;align-items:center;color:#fff;font-size:13px;padding-left:10px;">
          {{ s.pct_step }}%
        </div>
      </div>
      {% if not loop.first %}
        <div style="font-size:12px;color:#c0392b;margin-top:3px;">
          ↓ Abbruch zum vorherigen Schritt: {{ s.dropoff }}%
        </div>
      {% endif %}
    </div>
  {% endfor %}

  <p style="color:#888;font-size:12px;margin-top:20px;">
    Datenquelle: die vier „Funnel-…"-Ziele. Vergleich nach A/B-Variante:
    Segment „AB-Variante" hinzufügen.
  </p>
</div>
